# MPP-NEAR Configuration
# Copy this file to .env and fill in your values
# The .env file is automatically git-ignored

# ============================================================================
# NEAR Blockchain Configuration
# ============================================================================

# Your NEAR account ID
NEAR_ACCOUNT_ID=your-account.near

# Your NEAR private key (starts with ed25519:)
# Get this from your NEAR wallet
# WARNING: Keep this secret! Never commit to git!
NEAR_PRIVATE_KEY=ed25519:your_private_key_here

# NEAR RPC URL
# Mainnet: https://rpc.mainnet.near.org
# Testnet: https://rpc.testnet.near.org
NEAR_RPC_URL=https://rpc.mainnet.near.org

# ============================================================================
# OutLayer / NEAR Intents Configuration
# ============================================================================

# OutLayer API key for gasless payments
# Get your API key from: https://outlayer.fastnear.com
OUTLAYER_API_KEY=wk_your_api_key_here

# OutLayer API URL (usually don't need to change this)
OUTLAYER_API_URL=https://api.outlayer.fastnear.com

# ============================================================================
# MPP Server Configuration
# ============================================================================

# Server URL (for clients)
MPP_SERVER_URL=http://localhost:3000

# Payment method: "auto", "near", or "near-intents"
# auto: Automatically choose based on what's configured
# near: Use standard NEAR on-chain payments
# near-intents: Use gasless NEAR Intents payments
MPP_PAYMENT_METHOD=auto

# Maximum retry attempts for failed payments
MPP_MAX_RETRIES=3

# Delay between retries (in seconds)
MPP_RETRY_DELAY=2

# ============================================================================
# Agent Client Configuration
# ============================================================================

# Maximum amount to spend per single request (in USD)
MPP_AGENT_MAX_PER_REQUEST=0.10

# Maximum amount to spend per day (in USD)
MPP_AGENT_MAX_PER_DAY=5.00

# Enable/disable payment caching (true/false)
MPP_AGENT_CACHE_ENABLED=true

# ============================================================================
# Server-side Configuration
# ============================================================================

# HMAC secret for challenge binding
# Generate with: openssl rand -hex 32
# WARNING: Keep this secret! Use different value in production!
MPP_HMAC_SECRET=your-secret-here-change-in-production

# Recipient account for payments
MPP_RECIPIENT=merchant.near

# Challenge time-to-live in seconds
MPP_CHALLENGE_TTL=300

# ============================================================================
# CLI Configuration
# ============================================================================

# Suppress info messages (set to 1 for quiet mode)
MPP_NEAR_QUIET=0

# ============================================================================
# Optional: Client-specific overrides
# ============================================================================

# Override server URL for client
MPP_CLIENT_SERVER_URL=http://localhost:3000

# Override payment method for client
MPP_CLIENT_PAYMENT_METHOD=auto

# ============================================================================
# Example Configurations
# ============================================================================

# === Mainnet with NEAR Intents (Gasless) ===
# NEAR_ACCOUNT_ID=your-account.near
# OUTLAYER_API_KEY=wk_your_api_key
# MPP_PAYMENT_METHOD=near-intents

# === Testnet Configuration ===
# NEAR_ACCOUNT_ID=your-account.testnet
# NEAR_PRIVATE_KEY=ed25519:your_testnet_key
# NEAR_RPC_URL=https://rpc.testnet.near.org
# MPP_RECIPIENT=your-account.testnet
# MPP_PAYMENT_METHOD=near

# === Mainnet with Standard NEAR Payments ===
# NEAR_ACCOUNT_ID=your-account.near
# NEAR_PRIVATE_KEY=ed25519:your_mainnet_key
# NEAR_RPC_URL=https://rpc.mainnet.near.org
# MPP_RECIPIENT=merchant.near
# MPP_PAYMENT_METHOD=near
